{
  "manifest_version": 3,
  "name": "Calendar Helper",
  "description": "My first Google Calendar extension",
  "version": "1.0",

  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "permissions": []
}
